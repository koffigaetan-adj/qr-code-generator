rules_version = '2';

// Règles de sécurité pour les QR codes dynamiques.
// À déployer dans Firestore (Firebase Console → Firestore Database → Règles),
// ou via `firebase deploy --only firestore:rules` si vous avez la CLI Firebase.
service cloud.firestore {
  match /databases/{database}/documents {
    match /dynamicLinks/{code} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
